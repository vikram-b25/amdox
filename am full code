<script>
// ═══════════════════════════════════════════
// STATE & API
// ═══════════════════════════════════════════
const API_URL = 'http://localhost:5001/api';
let currentUser = null;
let selectedRole = 'seeker';
let jobs = [];
let applications = [];
let notifications = [
  { icon:'👋', title:'Welcome!', msg:'Log in to get started.', time:'Just now' }
];

// ── Inactivity Timer (3 min auto-logout) ──
const INACTIVITY_LIMIT = 3 * 60 * 1000; 
let inactivityTimer;

function resetInactivityTimer() {
  clearTimeout(inactivityTimer);
  inactivityTimer = setTimeout(handleAutoLogout, INACTIVITY_LIMIT);
}

function handleAutoLogout() {
  if (currentUser) {
    doLogout();
    toast('Session expired due to inactivity.', 'warn');
  }
}


async function api(endpoint, options = {}) {
  const token = localStorage.getItem('token');
  const headers = { 'Content-Type': 'application/json' };
  if (token) headers.Authorization = `Bearer ${token}`;
  
  const res = await fetch(`${API_URL}${endpoint}`, { ...options, headers });
  const data = await res.json();
  if (!res.ok) throw new Error(data.message || 'API Error');
  return data;
}

async function loadInitialData() {
  try {
    jobs = await api('/jobs');
    const sj = document.getElementById('statJobs');
    if (sj) sj.textContent = jobs.length;
    renderFeatured();
    const pj = document.getElementById('page-jobs');
    if (pj && pj.classList.contains('active')) renderJobs();
    
    const token = localStorage.getItem('token');
    if (token) {
      currentUser = await api('/auth/me');
      applications = await api('/applications');
      loginAs(currentUser, false);
    }
  } catch (err) {
    console.error(err);
  }
}
loadInitialData();



// ═══════════════════════════════════════════
// NAVIGATION
// ═══════════════════════════════════════════
function showPage(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-' + id).classList.add('active');
  if (id === 'jobs') renderJobs();
  if (id === 'home') renderFeatured();
  if (id === 'dashboard') renderDashboard();
  window.scrollTo(0,0);
}

function requireAuth(dest) {
  if (currentUser) { showPage('dashboard'); return; }
  showPage(dest);
}

// ═══════════════════════════════════════════
// AUTH
// ═══════════════════════════════════════════
function selectRole(r) {
  selectedRole = r;
  document.getElementById('roleSeeker').classList.toggle('selected', r==='seeker');
  document.getElementById('roleEmployer').classList.toggle('selected', r==='employer');
  document.getElementById('seekerFields').style.display = 'none'; // no seeker-specific fields now
  document.getElementById('employerFields').style.display = r==='employer' ? '' : 'none';
}

// ── Eye toggle ──
function toggleEye(inputId, svgId) {
  const inp = document.getElementById(inputId);
  const showing = inp.type === 'text';
  inp.type = showing ? 'password' : 'text';
  // swap icon: open-eye vs closed-eye
  document.getElementById(svgId).innerHTML = showing
    ? '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>'
    : '<path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/>';
}

// ── Password strength checker ──
function checkPwdStrength(val) {
  const rules = [
    { id: 'rule-len',     ok: val.length >= 8 },
    { id: 'rule-upper',  ok: /[A-Z]/.test(val) },
    { id: 'rule-num',    ok: /[0-9]/.test(val) },
    { id: 'rule-special',ok: /[^A-Za-z0-9]/.test(val) },
  ];
  rules.forEach(r => {
    const el = document.getElementById(r.id);
    el.classList.toggle('ok', r.ok);
  });
}



async function doLogin() {
  const email = document.getElementById('loginEmail').value.trim();
  const pwd = document.getElementById('loginPwd').value;
  if (!email || !pwd) { toast('Please fill in all fields.', 'warn'); return; }
  
  try {
    const data = await api('/auth/login', {
      method: 'POST', body: JSON.stringify({ email, password: pwd })
    });
    localStorage.setItem('token', data.token);
    applications = await api('/applications');
    loginAs(data);
  } catch (err) {
    toast(err.message, 'error');
  }
}

async function doRegister() {
  const first = document.getElementById('regFirst').value.trim();
  const last  = document.getElementById('regLast').value.trim();
  const email = document.getElementById('regEmail').value.trim();
  const pwd   = document.getElementById('regPwd').value;
  const pwd2  = document.getElementById('regPwdConfirm').value;
  if (!first||!last||!email||!pwd) { toast('Please complete all required fields.', 'warn'); return; }
  
  if (pwd.length < 8)            { toast('Password must be at least 8 characters.', 'warn'); return; }
  if (!/[A-Z]/.test(pwd))        { toast('Password needs an uppercase letter.', 'warn'); return; }
  if (!/[0-9]/.test(pwd))        { toast('Password needs a number.', 'warn'); return; }
  if (!/[^A-Za-z0-9]/.test(pwd)) { toast('Password needs a special character.', 'warn'); return; }
  if (pwd !== pwd2)              { toast('Passwords do not match.', 'error'); return; }
  
  const payload = { first, last, email, password: pwd, role: selectedRole };
  if (selectedRole==='employer') {
    payload.company = document.getElementById('regCompany').value;
    payload.industry = document.getElementById('regIndustry').value;
  }
  
  try {
    const data = await api('/auth/register', { method: 'POST', body: JSON.stringify(payload) });
    localStorage.setItem('token', data.token);
    applications = await api('/applications');
    notifications.push({ icon:'👋', title:'Welcome to Amdox Technologies!', msg:`Hi ${first}, your account is ready.`, time:'Just now' });
    loginAs(data);
  } catch (err) {
    toast(err.message, 'error');
  }
}

function loginAs(u, showTst = true) {
  currentUser = u;
  const nl = document.getElementById('navLinks');
  if (nl) nl.style.display = 'none';
  const nu = document.getElementById('navUser');
  if (nu) nu.style.display = 'flex';
  const initials = (u.first[0]+(u.last||'')[0]||'').toUpperCase();
  const na = document.getElementById('navAvatar');
  if (na) na.textContent = initials;
  if (showTst) toast(`Welcome back, ${u.first}! 👋`);
  showPage('dashboard');
}

function doLogout() {
  currentUser = null;
  localStorage.removeItem('token');
  const nl = document.getElementById('navLinks');
  if (nl) nl.style.display = 'flex';
  const nu = document.getElementById('navUser');
  if (nu) nu.style.display = 'none';
  toast('You\'ve been signed out.');
  showPage('home');
}

// ═══════════════════════════════════════════
// JOBS
// ═══════════════════════════════════════════
function renderFeatured() {
  const grid = document.getElementById('featuredGrid');
  if (grid) grid.innerHTML = jobs.slice(0,6).map(jobCard).join('');
}

function renderJobs() {
  const q = (document.getElementById('filterSearch')?.value||'').toLowerCase();
  const loc = (document.getElementById('filterLocation')?.value||'').toLowerCase();
  const type = document.getElementById('filterType')?.value||'';
  const industry = document.getElementById('filterIndustry')?.value||'';
  const salaryBand = document.getElementById('filterSalary')?.value||'';

  let filtered = jobs.filter(j => {
    if (q && !j.title.toLowerCase().includes(q) && !j.company.toLowerCase().includes(q)) return false;
    if (loc && !j.location.toLowerCase().includes(loc)) return false;
    if (type && j.type !== type) return false;
    if (industry && j.industry !== industry) return false;
    if (salaryBand === '0' && j.salaryNum >= 50) return false;
    if (salaryBand === '50' && (j.salaryNum < 50 || j.salaryNum >= 100)) return false;
    if (salaryBand === '100' && j.salaryNum < 100) return false;
    return true;
  });

  const jct = document.getElementById('jobCount');
  if (jct) jct.textContent = filtered.length + ' positions found';
  const ajg = document.getElementById('allJobsGrid');
  if (ajg) ajg.innerHTML = filtered.length ? filtered.map(jobCard).join('') : '<p style="color:var(--muted);grid-column:1/-1;padding:40px 0;text-align:center">No jobs match your filters.</p>';
}

function jobCard(j) {
  const id = j._id || j.id;
  const typePill = j.type==='Remote' ? 'pill-green' : j.type==='Contract' ? 'pill-orange' : 'pill-accent';
  return `<div class="job-card" onclick="openJob('${id}')">
    <div class="job-card-header">
      <div>
        <h3>${j.title}</h3>
        <div class="job-company">${j.company} · ${j.industry}</div>
      </div>
      <div class="company-logo">${j.emoji}</div>
    </div>
    <div class="job-meta">
      <div class="job-meta-item"><svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>${j.location}</div>
      <div class="job-meta-item"><svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>${j.posted}</div>
    </div>
    <div class="job-tags">
      <span class="pill ${typePill}">${j.type}</span>
      <span class="pill">${j.salary}</span>
    </div>
  </div>`;
}

function openJob(id) {
  const j = jobs.find(j=>(j._id === id || j.id === id));
  if (!j) return;
  const alreadyApplied = currentUser && applications.find(a=>(a.jobId?._id === id || a.jobId === id) && (a.seekerId?._id === (currentUser._id || currentUser.id) || a.seekerId === (currentUser._id || currentUser.id)));
  const canApply = currentUser && currentUser.role==='seeker' && !alreadyApplied;

  const mc = document.getElementById('modalContent');
  if (mc) mc.innerHTML = `
    <h2>${j.title}</h2>
    <div class="modal-company">${j.company} · ${j.location}</div>
    <div class="job-tags" style="margin-bottom:20px">
      <span class="pill pill-accent">${j.type}</span>
      <span class="pill pill-green">${j.salary}</span>
      <span class="pill">${j.industry}</span>
    </div>
    <div class="modal-section"><h4>About the Role</h4><p>${j.desc}</p></div>
    <div class="modal-section"><h4>Qualifications</h4><p>${j.qual}</p></div>
    <div class="modal-section"><h4>Responsibilities</h4><p>${j.resp}</p></div>
    <div class="modal-actions">
      ${canApply ? `<button class="btn btn-accent" onclick="applyJob('${id}')">Apply Now</button>` : ''}
      ${alreadyApplied ? `<span class="pill pill-green" style="padding:10px 18px">✓ Applied</span>` : ''}
      ${!currentUser ? `<button class="btn btn-accent" onclick="closeModal();showPage('register')">Sign Up to Apply</button>` : ''}
    </div>`;
  document.getElementById('jobModal').classList.add('open');
}

function closeModal() { document.getElementById('jobModal').classList.remove('open'); }

async function applyJob(jobId) {
  if (!currentUser || currentUser.role!=='seeker') return;
  const uid = currentUser._id || currentUser.id;
  if (applications.find(a=>(a.jobId?._id===jobId || a.jobId===jobId) && (a.seekerId?._id===uid || a.seekerId===uid))) { toast('Already applied!'); return; }
  
  try {
    const app = await api('/applications', { method: 'POST', body: JSON.stringify({ jobId }) });
    applications = await api('/applications'); // reload
    notifications.push({ icon:'📬', title:'Application Submitted!', msg:`Your application is under review.`, time:'Just now' });
    closeModal();
    toast('Application submitted! 🎉');
    renderDashboard();
  } catch(err) {
    toast(err.message, 'error');
  }
}

function doHeroSearch() {
  const q = document.getElementById('heroSearch').value;
  showPage('jobs');
  setTimeout(()=>{ document.getElementById('filterSearch').value=q; renderJobs(); },100);
}

// ═══════════════════════════════════════════
// DASHBOARD
// ═══════════════════════════════════════════
function renderDashboard() {
  if (!currentUser) return;
  const u = currentUser;
  const uid = u._id || u.id;
  const initials = (u.first[0]+(u.last||'')[0]).toUpperCase();
  const da = document.getElementById('dashAvatar');
  if (da) da.textContent = initials;
  const dn = document.getElementById('dashName');
  if (dn) dn.textContent = `${u.first} ${u.last}`;
  const dr = document.getElementById('dashRole');
  if (dr) dr.textContent = u.role==='seeker' ? (u.title||'Job Seeker') : (u.company||'Employer');

  // employer/seeker tabs
  const mjt = document.getElementById('myJobsTab');
  if (mjt) mjt.style.display = u.role==='employer' ? '' : 'none';
  const pjt = document.getElementById('postJobTab');
  if (pjt) pjt.style.display = u.role==='employer' ? '' : 'none';
  const apt = document.getElementById('applicationsTab');
  if (apt) apt.style.display = u.role==='seeker' ? '' : 'none';
  const avt = document.getElementById('availableJobsTab');
  if (avt) avt.style.display = u.role==='seeker' ? '' : 'none';


  // KPIs
  const myApps = applications.filter(a=>(a.seekerId?._id===uid || a.seekerId===uid));
  const myJobs = jobs.filter(j=>(j.employerId?._id===uid || j.employerId===uid));
  const myNotifs = notifications.length;

  const kpiRow = document.getElementById('kpiRow');
  if (kpiRow) {
    if (u.role==='seeker') {
      kpiRow.innerHTML = `
        <div class="kpi"><div class="kpi-val">${myApps.length}</div><div class="kpi-lbl">Applications</div></div>
        <div class="kpi"><div class="kpi-val">${myApps.filter(a=>a.status==='Interview Scheduled').length}</div><div class="kpi-lbl">Interviews</div></div>
        <div class="kpi"><div class="kpi-val">${myNotifs}</div><div class="kpi-lbl">Notifications</div></div>`;
    } else {
      const myJobIds = myJobs.map(j=>(j._id || j.id));
      const inbound = applications.filter(a=>myJobIds.includes(a.jobId?._id || a.jobId)).length;
      kpiRow.innerHTML = `
        <div class="kpi"><div class="kpi-val">${myJobs.length}</div><div class="kpi-lbl">Active Listings</div></div>
        <div class="kpi"><div class="kpi-val">${inbound}</div><div class="kpi-lbl">Applicants</div></div>
        <div class="kpi"><div class="kpi-val">${myNotifs}</div><div class="kpi-lbl">Notifications</div></div>`;
    }
  }

  // Recent
  const recentCard = document.getElementById('recentCard');
  if (recentCard) {
    if (u.role==='seeker') {
      const rows = myApps.slice(-4).reverse().map(a=>{
        const j = jobs.find(j=>(j._id===(a.jobId?._id||a.jobId) || j.id===(a.jobId?._id||a.jobId)));
        const dotC = a.status==='Interview Scheduled'?'dot-green':a.status==='Under Review'?'dot-yellow':'dot-orange';
        return `<div class="list-item">
          <div class="list-item-left"><div class="dot ${dotC}"></div>
            <div class="list-item-info"><h4>${j?.title||'Unknown Role'}</h4><p>${j?.company} · ${a.appliedDate}</p></div>
          </div>
          <span class="pill ${a.status==='Interview Scheduled'?'pill-green':''}">${a.status}</span>
        </div>`;
      }).join('');
      recentCard.innerHTML = `<h3>Recent Applications</h3>${rows||'<p style="color:var(--muted)">No applications yet. <a style="color:var(--accent);cursor:pointer" onclick="showPage(\'jobs\')">Browse jobs →</a></p>'}`;
    } else {
      const rows = myJobs.slice(-4).map(j=>{
        const jid = j._id || j.id;
        const count = applications.filter(a=>(a.jobId?._id===jid || a.jobId===jid)).length;
        return `<div class="list-item">
          <div class="list-item-left"><div class="dot dot-yellow"></div>
            <div class="list-item-info"><h4>${j.title}</h4><p>${j.location} · ${j.type}</p></div>
          </div>
          <span class="pill">${count} applicant${count!==1?'s':''}</span>
        </div>`;
      }).join('');
      recentCard.innerHTML = `<h3>My Job Listings</h3>${rows||'<p style="color:var(--muted)">No listings yet.</p>'}`;
    }
  }

  // Profile form
  buildProfileForm();
  // Applications list
  buildApplicationsList();
  // My jobs list
  buildMyJobsList();
  // Notifications
  buildNotifications();
  // Available Jobs
  buildAvailableJobsList();
}


function dashTab(tab, el) {
  document.querySelectorAll('.sidebar-item').forEach(s=>s.classList.remove('active'));
  el.classList.add('active');
  const panels = ['overview','profile','applications','myjobs','postjob','notifications','available'];
  panels.forEach(p => { const el = document.getElementById('panel-'+p); if(el) el.style.display='none'; });
  const target = document.getElementById('panel-'+tab);
  if (target) target.style.display='';
}


function buildProfileForm() {
  const u = currentUser;
  const f = document.getElementById('profileForm');
  if (!f) return;
  if (u.role==='seeker') {
    f.innerHTML = `
      <div class="form-row">
        <div class="form-group"><label>First Name</label><input id="pfFirst" value="${u.first}"/></div>
        <div class="form-group"><label>Last Name</label><input id="pfLast" value="${u.last}"/></div>
      </div>
      <div class="form-group"><label>Email</label><input id="pfEmail" value="${u.email}"/></div>
      <div class="form-group"><label>Current Title</label><input id="pfTitle" value="${u.title||''}"/></div>
      <div class="form-group"><label>About Me</label><textarea id="pfAbout" placeholder="Tell employers about yourself…">${u.about||''}</textarea></div>
      <div class="form-group"><label>Skills (comma-separated)</label><input id="pfSkills" value="${u.skills||''}" placeholder="React, TypeScript, CSS"/></div>
      <div class="form-group"><label>Resume/Portfolio Link</label><input id="pfResume" value="${u.resumeUrl||''}" placeholder="https://drive.google.com/your-resume"/></div>
      <button class="btn btn-accent" onclick="saveProfile()">Save Changes</button>`;
  } else {
    f.innerHTML = `
      <div class="form-row">
        <div class="form-group"><label>First Name</label><input id="pfFirst" value="${u.first}"/></div>
        <div class="form-group"><label>Last Name</label><input id="pfLast" value="${u.last}"/></div>
      </div>
      <div class="form-group"><label>Email</label><input id="pfEmail" value="${u.email}"/></div>
      <div class="form-group"><label>Company Name</label><input id="pfCompany" value="${u.company||''}"/></div>
      <div class="form-group"><label>Industry</label><input id="pfIndustry" value="${u.industry||''}"/></div>
      <div class="form-group"><label>Company Bio</label><textarea id="pfBio" placeholder="Describe your company…">${u.bio||''}</textarea></div>
      <button class="btn btn-accent" onclick="saveProfile()">Save Changes</button>`;
  }
}

async function saveProfile() {
  const payload = {
    first: document.getElementById('pfFirst').value,
    last: document.getElementById('pfLast').value,
    email: document.getElementById('pfEmail').value
  };
  if (currentUser.role==='seeker') {
    payload.title = document.getElementById('pfTitle').value;
    payload.about = document.getElementById('pfAbout').value;
    payload.skills = document.getElementById('pfSkills').value;
    payload.resumeUrl = document.getElementById('pfResume').value;
  } else {
    payload.company = document.getElementById('pfCompany').value;
    payload.industry = document.getElementById('pfIndustry').value;
    payload.bio = document.getElementById('pfBio').value;
  }
  
  try {
    currentUser = await api('/auth/profile', { method: 'PUT', body: JSON.stringify(payload) });
    renderDashboard();
    toast('Profile updated! ✓');
  } catch(err) {
    toast(err.message, 'error');
  }
}

function buildApplicationsList() {
  const list = document.getElementById('applicationsList');
  if (!list) return;
  const uid = currentUser?._id || currentUser?.id;
  const myApps = applications.filter(a=>(a.seekerId?._id===uid || a.seekerId===uid));
  if (!myApps.length) { list.innerHTML='<p style="color:var(--muted)">No applications yet.</p>'; return; }
  list.innerHTML = myApps.map(a=>{
    const j = jobs.find(j=>(j._id===(a.jobId?._id||a.jobId) || j.id===(a.jobId?._id||a.jobId)));
    const dotC = a.status==='Interview Scheduled'?'dot-green':'dot-yellow';
    return `<div class="list-item">
      <div class="list-item-left"><div class="dot ${dotC}"></div>
        <div class="list-item-info"><h4>${j?.title || 'Unknown Job'}</h4><p>${j?.company || 'Unknown Company'} · Applied ${a.appliedDate}</p></div>
      </div>
      <div style="display:flex;align-items:center;gap:10px">
        <span class="pill ${a.status==='Interview Scheduled'?'pill-green':''}">${a.status}</span>
        <button class="btn btn-danger btn-sm" onclick="withdrawApp('${a._id}')">Withdraw</button>
      </div>
    </div>`;
  }).join('');
}

async function withdrawApp(id) {
  try {
    await api(`/applications/${id}`, { method: 'DELETE' });
    applications = await api('/applications');
    buildApplicationsList();
    renderDashboard();
    toast('Application withdrawn.');
  } catch(err) {
    toast(err.message, 'error');
  }
}

function buildMyJobsList() {
  const list = document.getElementById('myJobsList');
  if (!list) return;
  const uid = currentUser?._id || currentUser?.id;
  const myJobs = jobs.filter(j=>(j.employerId?._id===uid || j.employerId===uid));
  if (!myJobs.length) { list.innerHTML='<p style="color:var(--muted)">No listings yet. <a style="color:var(--accent);cursor:pointer" onclick="dashTab(\'postjob\',document.getElementById(\'postJobTab\'))">Post your first job →</a></p>'; return; }
  list.innerHTML = myJobs.map(j=>{
    const jid = j._id || j.id;
    const count = applications.filter(a=>(a.jobId?._id===jid || a.jobId===jid)).length;
    return `<div class="list-item">
      <div class="list-item-left">
        <div class="company-logo" style="width:36px;height:36px;font-size:.9rem">${j.emoji || '🏢'}</div>
        <div class="list-item-info"><h4>${j.title}</h4><p>${j.location} · ${j.type} · ${count} applicant${count!==1?'s':''}</p></div>
      </div>
      <div style="display:flex;gap:8px">
        <button class="btn btn-ghost btn-sm" onclick="openApplicants('${j._id}')">View Applicants</button>
        <button class="btn btn-danger btn-sm" onclick="deleteJob('${j._id}')">Delete</button>
      </div>
    </div>`;
  }).join('');
}

async function deleteJob(id) {
  try {
    await api(`/jobs/${id}`, { method: 'DELETE' });
    jobs = await api('/jobs');
    applications = await api('/applications');
    buildMyJobsList();
    renderDashboard();
    toast('Listing removed.');
    if (document.getElementById('page-jobs').classList.contains('active')) renderJobs();
    renderFeatured();
  } catch (err) {
    toast(err.message, 'error');
  }
}

function openApplicants(jobId) {
  const j = jobs.find(j => (j._id || j.id) === jobId);
  if (!j) return;
  const myApps = applications.filter(a => (a.jobId?._id || a.jobId) === jobId);
  
  const mt = document.getElementById('appModalTitle');
  if (mt) mt.textContent = `Applicants for ${j.title}`;
  const ms = document.getElementById('appModalSub');
  if (ms) ms.textContent = `${myApps.length} candidate${myApps.length!==1?'s':''} applied`;
  
  const cont = document.getElementById('applicantsContainer');
  if (!cont) return;
  if (!myApps.length) {
    cont.innerHTML = '<p style="color:var(--muted);padding:20px 0;text-align:center">No applicants yet for this listing.</p>';
  } else {
    cont.innerHTML = myApps.map(a => {
      const s = a.seekerId;
      const initials = (s?.first ? s.first[0] : 'U') + (s?.last ? s.last[0] : '');
      const skills = s?.skills ? s.skills.split(',').map(sk => `<span class="pill" style="margin-right:4px">${sk.trim()}</span>`).join('') : '';
      
      return `
        <div class="list-item" style="padding:20px 0; border-bottom:1px solid var(--border); display:block">
          <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:12px">
            <div class="list-item-left">
              <div class="avatar" style="width:44px;height:44px;background:var(--surface2);border:1px solid var(--border)">${initials.toUpperCase()}</div>
              <div class="list-item-info">
                <h4 style="font-size:1.1rem">${s?.first || 'Unknown'} ${s?.last || ''}</h4>
                <p style="margin-top:2px">${s?.title || 'Job Seeker'} · <a href="mailto:${s?.email}" style="color:var(--accent);text-decoration:none">${s?.email || 'No Email'}</a></p>
              </div>
            </div>
            <select class="btn btn-ghost btn-sm" onchange="updateAppStatus('${a._id}', this.value)" style="background:var(--surface2);color:var(--text);border:1px solid var(--border)">
              <option ${a.status==='Under Review'?'selected':''}>Under Review</option>
              <option ${a.status==='Interview Scheduled'?'selected':''}>Interview Scheduled</option>
              <option ${a.status==='Hired'?'selected':''}>Hired</option>
              <option ${a.status==='Rejected'?'selected':''}>Rejected</option>
            </select>
          </div>
          
          ${s?.about ? `<div style="margin-bottom:12px"><h5 style="color:var(--muted);font-size:0.75rem;text-transform:uppercase;margin-bottom:4px">About</h5><p style="font-size:0.87rem;color:rgba(232,234,240,0.8)">${s.about}</p></div>` : ''}
          ${skills ? `<div style="margin-bottom:12px"><h5 style="color:var(--muted);font-size:0.75rem;text-transform:uppercase;margin-bottom:4px">Skills</h5><div>${skills}</div></div>` : ''}
          
          <div style="display:flex; justify-content:space-between; align-items:center; margin-top:16px">
            <p style="font-size:0.75rem;color:var(--muted)">Applied on ${a.appliedDate}</p>
            <div style="display:flex; gap:8px">
              <a href="mailto:${s?.email}" class="btn btn-accent btn-sm">Contact Candidate ✉️</a>
              ${s?.resumeUrl ? `<a href="${s.resumeUrl}" target="_blank" class="btn btn-ghost btn-sm" style="background:rgba(240,192,64,0.1); border-color:var(--accent); color:var(--accent)">View Resume 📄</a>` : ''}
            </div>
          </div>
        </div>`;

    }).join('');
  }
  document.getElementById('applicantsModal').classList.add('open');
}

function closeApplicantsModal() { document.getElementById('applicantsModal').classList.remove('open'); }

async function updateAppStatus(appId, status) {
  try {
    await api(`/applications/${appId}`, { method: 'PUT', body: JSON.stringify({ status }) });
    applications = await api('/applications'); // reload
    toast('Status updated! ✓');
    renderDashboard();
    // Refresh modal if open
    if (document.getElementById('applicantsModal').classList.contains('open')) {
       const app = applications.find(a=>a._id===appId);
       if (app) openApplicants(app.jobId?._id || app.jobId);
    }
  } catch(err) {
    toast(err.message, 'error');
  }
}

function buildNotifications() {
  const nl = document.getElementById('notifList');
  if (!nl) return;
  nl.innerHTML = notifications.slice().reverse().map(n=>`
    <div class="notif-item">
      <div class="notif-icon">${n.icon}</div>
      <div><h4>${n.title}</h4><p>${n.msg}</p></div>
      <div class="notif-time">${n.time}</div>
    </div>`).join('');
}

function buildAvailableJobsList() {
  const grid = document.getElementById('availableJobsGrid');
  if (!grid) return;
  grid.innerHTML = jobs.length 
    ? jobs.map(jobCard).join('') 
    : '<p style="color:var(--muted);grid-column:1/-1;padding:40px 0;text-align:center">No jobs available at the moment.</p>';
}


async function postJob() {
  const tEl = document.getElementById('pjTitle');
  const dEl = document.getElementById('pjDesc');
  const title = tEl.value.trim();
  const desc = dEl.value.trim();
  
  // Clear previous errors
  tEl.style.borderColor = '';
  dEl.style.borderColor = '';

  if (!title || !desc) {
    if (!title) tEl.style.borderColor = 'var(--danger)';
    if (!desc) dEl.style.borderColor = 'var(--danger)';
    toast('Please fill in the required fields highlighted in red.', 'warn');
    return;
  }
  
  const payload = {
    title, desc,
    company: currentUser.company || `${currentUser.first}'s Company`,
    industry: document.getElementById('pjIndustry').value,
    type: document.getElementById('pjType').value,
    location: document.getElementById('pjLocation').value || 'Not specified',
    salary: document.getElementById('pjSalary').value || 'Competitive',
    qual: document.getElementById('pjQual').value,
    resp: document.getElementById('pjResp').value,
    salaryNum: 50 // simplistic for now
  };

  try {
    await api('/jobs', { method: 'POST', body: JSON.stringify(payload) });
    jobs = await api('/jobs'); // refresh jobs list
    const sj = document.getElementById('statJobs');
    if (sj) sj.textContent = jobs.length;
    ['pjTitle','pjLocation','pjSalary','pjDesc','pjQual','pjResp'].forEach(id=>{ const el=document.getElementById(id); if(el) el.value=''; });
    notifications.push({ icon:'📌', title:'Job Published!', msg:`"${title}" is now live on Amdox Technologies.`, time:'Just now' });
    renderDashboard();
    toast('Job published successfully! 🎉');
    if (document.getElementById('page-jobs').classList.contains('active')) renderJobs();
    renderFeatured();
  } catch(err) {
    toast(err.message, 'error');
  }
}

// ═══════════════════════════════════════════
// TOAST
// ═══════════════════════════════════════════
let toastTimer;
function toast(msg, type='success') {
  const el = document.getElementById('toast');
  const dot = document.getElementById('toastDot');
  document.getElementById('toastMsg').textContent = msg;
  dot.style.background = type==='error'?'var(--danger)':type==='warn'?'var(--accent)':'var(--success)';
  el.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(()=>el.classList.remove('show'), 3200);
}

// Close modal on overlay click
document.getElementById('jobModal').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});

// ═══════════════════════════════════════════
// PASSWORD RECOVERY
// ═══════════════════════════════════════════
let recoveryEmail = '';

function openForgotModal() { document.getElementById('forgotModal').classList.add('open'); }
function closeForgotModal() { document.getElementById('forgotModal').classList.remove('open'); }
function closeResetModal() { document.getElementById('resetModal').classList.remove('open'); }

async function doForgotRequest() {
  const email = document.getElementById('forgotEmail').value.trim();
  if (!email) { toast('Please enter your email.', 'warn'); return; }
  
  try {
    await api('/auth/forgot-password', { method: 'POST', body: JSON.stringify({ email }) });
    recoveryEmail = email;
    closeForgotModal();
    document.getElementById('resetEmailSpan').textContent = email;
    document.getElementById('resetModal').classList.add('open');
    toast('Account verified! Choose a new password.');
  } catch (err) {
    toast(err.message, 'error');
  }
}

async function doResetPassword() {
  const pwd = document.getElementById('resetNewPwd').value;
  const pwd2 = document.getElementById('resetConfirmPwd').value;
  
  if (!pwd || pwd.length < 8) { toast('Password must be at least 8 characters.', 'warn'); return; }
  if (pwd !== pwd2) { toast('Passwords do not match.', 'warn'); return; }
  
  try {
    await api('/auth/reset-password', { 
      method: 'POST', 
      body: JSON.stringify({ email: recoveryEmail, password: pwd }) 
    });
    closeResetModal();
    toast('Password updated successfully! You can now sign in.');
    showPage('login');
  } catch (err) {
    toast(err.message, 'error');
  }
}

// Init
renderFeatured();
resetInactivityTimer(); // Start inactivity timer

// global activity listeners
['mousemove', 'mousedown', 'keypress', 'scroll', 'touchstart'].forEach(evt => {
  window.addEventListener(evt, resetInactivityTimer, true);
});


const sjFinal = document.getElementById('statJobs');
if (sjFinal) sjFinal.textContent = jobs.length;
</script>
